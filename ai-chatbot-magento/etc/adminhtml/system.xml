<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="ai_chatbot" translate="label" sortOrder="960" showInDefault="1" showInWebsite="1" showInStore="0">
            <label>AI Chatbot</label>
            <tab>catalog</tab>
            <resource>Czar_AiChatbot::config</resource>
            <group id="general" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0">
                <label>General Settings</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Enable Module</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="api_url" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Endpoint URL Override</label>
                </field>
                <field id="api_key" translate="label" type="obscure" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>API Key Override</label>
                </field>
                <field id="license_key" translate="label" type="obscure" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>License Key Override</label>
                </field>
                <field id="llm_provider" translate="label" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>LLM Provider Override</label>
                </field>
                <field id="llm_model" translate="label" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>LLM Model Override</label>
                </field>
                <field id="llm_api_key" translate="label" type="obscure" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>LLM API Key Override</label>
                </field>
                <field id="welcome_message" translate="label" type="textarea" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Welcome Message</label>
                </field>
                <field id="fallback_message" translate="label" type="textarea" sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Grounded Refusal Message</label>
                </field>
            </group>
            <group id="widget" translate="label" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="0">
                <label>Widget</label>
                <field id="show_widget" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Show Storefront Widget</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="position" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Widget Position</label>
                </field>
                <field id="title" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Widget Title</label>
                </field>
                <field id="theme_color" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Theme Color</label>
                </field>
                <field id="starter_prompts" translate="label" type="textarea" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Starter Prompts</label>
                    <comment>Separate prompts with "|" or new lines.</comment>
                </field>
            </group>
            <group id="sync" translate="label" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="0">
                <label>Sync</label>
                <field id="auto_sync_enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Enable Scheduled Sync</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="cron_expression" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Cron Expression</label>
                </field>
                <field id="batch_size" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Batch Size</label>
                </field>
                <field id="review_limit" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Review Batch Limit</label>
                </field>
            </group>
            <group id="history" translate="label" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="0">
                <label>History</label>
                <field id="retain_days" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Retention Days</label>
                </field>
                <field id="link_customer_sessions" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Link Logged-in Sessions to Customer ID</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
    </system>
</config>
