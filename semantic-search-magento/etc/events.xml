<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="catalog_product_save_after">
        <observer name="czar_semanticsearch_product_save" instance="Czar\SemanticSearch\Observer\ProductSaveAfter"/>
    </event>
    <event name="catalog_product_delete_after_done">
        <observer name="czar_semanticsearch_product_delete" instance="Czar\SemanticSearch\Observer\ProductDeleteAfter"/>
    </event>
</config>
