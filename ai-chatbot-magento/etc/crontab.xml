<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="ai_chatbot_process_running_sync"
             instance="Czar\AiChatbot\Cron\ProcessSyncQueue"
             method="execute">
            <schedule>*/5 * * * *</schedule>
        </job>
        <job name="ai_chatbot_schedule_full_sync"
             instance="Czar\AiChatbot\Cron\RunScheduledSync"
             method="execute">
            <config_path>ai_chatbot/sync/cron_expression</config_path>
        </job>
    </group>
</config>
